#include "rtl8198c.dtsi"

/ {
	compatible = "askey,ap5100w", "realtek,rtl8198c-soc";
	model = "Askey AP5100W";

	/*
	 * The old RTL8198C BSP kernel reports 256 MiB DDR3
	 * (memory: 10000000 @ 00000000).  Our 6.18 kernel
	 * currently only sees 128 MiB — may be a bank-select
	 * or memory-controller init issue.
	 */
	memory@0 {
		device_type = "memory";
		reg = <0x0 0x10000000>;
	};

	leds {
		compatible = "gpio-leds";

		/*
		 * GPIO assignments below are from the old BSP boot log
		 * and are TENTATIVE.  The old kernel reports:
		 *   GPIO_MUX3 = 0x4924801b  GPIO_MUX4 = 0x180001b  GPIO_MUX5 = 0xffc003
		 * GPIO pins need vendor schematics / original DTS for confirmation.
		 */

		led_wifi2g: wifi2g {
			label = "green:wifi2g";
			gpios = <&gpio1 31 1>;  /* tentative: GPIOH7 */
		};

		led_wifi5g: wifi5g {
			label = "green:wifi5g";
			gpios = <&gpio1 16 1>;  /* tentative: GPIOG0 */
		};
	};
};

/*
 * NAND flash (Winbond W29N01HV, 128 MiB).
 *
 * U-Boot layout — all block-aligned (block = 128 KiB):
 *   Offset      Size     Label        Purpose
 *   0x000000    2 MiB    u-boot       SPL + U-Boot proper
 *   0x200000    256 KiB  u-boot-env   Redundant environment
 *   0x240000    3 MiB    factory      Preserved vendor cal (read-only)
 *   0x540000   48 MiB    firmware     Primary OS (kernel + squashfs)
 *   0x354000   30 MiB    rescue       LZMA recovery image (read-only)
 *   0x534000   ~38 MiB   ubi          UBIFS persistent overlay
 *   0x7A0000    2 MiB    nvdata       Vendor NVRAM
 *
 * Old vendor layout (for reference):
 *   5m@0x0(boot),3m@0x500000(setting),6m@0x800000(linux),
 *   24m@0xe00000(rootfs),6m@0x2600000(linux2),24m@0x2C00000(rootfs2),
 *   38m@0x4400000(data),2m@0x6A00000(nvdata)
 */

&nand {
	status = "okay";

	nand-chip@0 {
		reg = <0>;

		partitions {
			compatible = "fixed-partitions";
			#address-cells = <1>;
			#size-cells = <1>;

			partition@0 {
				label = "u-boot";
				reg = <0x0000000 0x200000>;
				read-only;
			};

			partition@200000 {
				label = "u-boot-env";
				reg = <0x0200000 0x40000>;
				read-only;
			};

			partition@240000 {
				label = "factory";
				reg = <0x0240000 0x300000>;
				read-only;
			};

			partition@540000 {
				label = "firmware";
				reg = <0x0540000 0x3000000>;
			};

			partition@3540000 {
				label = "rescue";
				reg = <0x3540000 0x1e00000>;
				read-only;
			};

			partition@5340000 {
				label = "ubi";
				reg = <0x5340000 0x26c0000>;
			};

			partition@7a00000 {
				label = "nvdata";
				reg = <0x7a00000 0x200000>;
			};
		};
	};
};

&eth {
	status = "okay";
	local-mac-address = [CA FE BA BE 00 00];
};

&gsw {
	status = "okay";
};

&xhci {
	status = "okay";
};

/dts-v1/;

#include "bcm63178.dtsi"
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>
#include <dt-bindings/leds/common.h>

/ {
	model = "Arcadyan WG660242-ST";
	compatible = "arcadyan,wg660242-st", "brcm,bcm63178", "brcm,bcmbca";

	aliases {
		serial0 = &uart0;
	};

	chosen {
		stdout-path = "serial0:115200n8";
	};

	memory@0 {
		device_type = "memory";
		reg = <0x0 0x20000000>;
	};

	reserved-memory {
		#address-cells = <1>;
		#size-cells = <1>;
		ranges;

		cma@1f400000 {
			compatible = "shared-dma-pool";
			reusable;
			reg = <0x1f400000 0xc00000>;
		};
	};

	wdt-reboot {
		compatible = "wdt-reboot";
		wdt = <&watchdog>;
	};

	gpio-keys {
		compatible = "gpio-keys-polled";
		poll-interval = <20>;

		reset {
			label = "reset";
			gpios = <&gpio0 0 GPIO_ACTIVE_LOW>;
			linux,code = <KEY_RESTART>;
		};

		wps {
			label = "wps";
			gpios = <&gpio0 1 GPIO_ACTIVE_LOW>;
			linux,code = <KEY_WPS_BUTTON>;
		};
	};

	gpio-leds {
		compatible = "gpio-leds";

		led-lan {
			label = "green:lan";
			gpios = <&gpio0 5 GPIO_ACTIVE_LOW>;
		};

		led-power-white {
			label = "white:power";
			gpios = <&gpio0 6 GPIO_ACTIVE_LOW>;
		};

		led-power-red {
			label = "red:power";
			gpios = <&gpio0 7 GPIO_ACTIVE_LOW>;
		};

		led-mesh-white {
			label = "white:mesh";
			gpios = <&gpio0 8 GPIO_ACTIVE_LOW>;
		};

		led-mesh-red {
			label = "red:mesh";
			gpios = <&gpio0 9 GPIO_ACTIVE_LOW>;
		};

		led-internet-white {
			label = "white:internet";
			gpios = <&gpio0 10 GPIO_ACTIVE_LOW>;
		};

		led-internet-red {
			label = "red:internet";
			gpios = <&gpio0 11 GPIO_ACTIVE_LOW>;
		};
	};
};

&uart0 {
	status = "okay";
};

&nand_controller {
	brcm,wp-not-connected;
	status = "okay";
};

&nandcs {
	nand-on-flash-bbt;
	brcm,nand-ecc-use-strap;
};

&watchdog {
	status = "okay";
};

&gpio0 {
	status = "okay";
};

&gpio1 {
	status = "okay";
};

&gpio2 {
	ngpios = <24>;
	status = "okay";
};

&leds {
	status = "okay";
	brcm,serial-shift-bits = <32>;
};

&pl081_dma {
	status = "okay";
};

&pmc {
	status = "okay";
};

&boot_state {
	status = "okay";
};
